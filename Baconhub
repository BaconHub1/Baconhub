-- Map of leetspeak chars to letters
local leetMap = {
    ["4"] = "a",
    ["@"] = "a",
    ["8"] = "b",
    ["3"] = "e",
    ["1"] = "i",
    ["0"] = "o",
    ["5"] = "s",
    ["7"] = "t",
    ["$"] = "s",
}

local function normalizeText(text)
    text = text:lower()
    -- Replace leetspeak numbers/symbols with letters
    for leetChar, letter in pairs(leetMap) do
        text = text:gsub(leetChar, letter)
    end
    -- Remove all non-alphabetic characters to catch disguised words
    text = text:gsub("[^a-z]", "")
    return text
end

local function containsBadWords(msg)
    local cleaned = normalizeText(msg)
    for _, badword in ipairs(blacklist) do
        local normBadword = normalizeText(badword)
        if cleaned:find(normBadword, 1, true) then
            return true
        end
    end
    return false
end

