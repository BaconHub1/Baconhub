-- BaconHub KING Loader (Clean Premium)

local player = game.Players.LocalPlayer
local name = player.DisplayName or player.Name

local gui = Instance.new("ScreenGui")
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local TweenService = game:GetService("TweenService")

-- BACKGROUND
local bg = Instance.new("Frame")
bg.Size = UDim2.new(1,0,1,0)
bg.BackgroundColor3 = Color3.fromRGB(10,10,10)
bg.Parent = gui

-- SOFT GRADIENT (depth)
local grad = Instance.new("UIGradient")
grad.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(15,15,15)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(5,5,5))
}
grad.Rotation = 90
grad.Parent = bg

-- LOGO
local logo = Instance.new("ImageLabel")
logo.Size = UDim2.new(0,110,0,110)
logo.Position = UDim2.new(0.5,-55,0.38,0)
logo.BackgroundTransparency = 1
logo.Image = "rbxassetid://114302082036991"
logo.ImageTransparency = 1
logo.Parent = bg

-- TITLE
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0.05,0)
title.Position = UDim2.new(0,0,0.5,0)
title.BackgroundTransparency = 1
title.Text = "BaconHub"
title.Font = Enum.Font.GothamSemibold
title.TextScaled = true
title.TextColor3 = Color3.fromRGB(235,235,235)
title.TextTransparency = 1
title.Parent = bg

-- LOADING BAR
local barBG = Instance.new("Frame")
barBG.Size = UDim2.new(0.28,0,0.012,0)
barBG.Position = UDim2.new(0.36,0,0.58,0)
barBG.BackgroundColor3 = Color3.fromRGB(35,35,35)
barBG.BorderSizePixel = 0
barBG.Parent = bg

local bar = Instance.new("Frame")
bar.Size = UDim2.new(0,0,1,0)
bar.BackgroundColor3 = Color3.fromRGB(255,120,0)
bar.BorderSizePixel = 0
bar.Parent = barBG

-- STATUS TEXT
local status = Instance.new("TextLabel")
status.Size = UDim2.new(1,0,0.04,0)
status.Position = UDim2.new(0,0,0.62,0)
status.BackgroundTransparency = 1
status.Font = Enum.Font.Gotham
status.TextScaled = true
status.TextColor3 = Color3.fromRGB(140,140,140)
status.Text = ""
status.TextTransparency = 1
status.Parent = bg

-- INTRO ANIMATION (fade + slight rise)
TweenService:Create(logo, TweenInfo.new(0.6, Enum.EasingStyle.Quad), {
	ImageTransparency = 0,
	Position = UDim2.new(0.5,-55,0.36,0)
}):Play()

TweenService:Create(title, TweenInfo.new(0.6), {
	TextTransparency = 0
}):Play()

task.wait(0.4)

TweenService:Create(status, TweenInfo.new(0.4), {
	TextTransparency = 0
}):Play()

-- PREMIUM SPIN LOGO ANIMATION

task.spawn(function()
	local t = 0
	local rotationSpeed = 720 -- start super fast (degrees per second)
	local deceleration = 100 -- slow down over time

	while true do
		local dt = task.wait()
		t += dt

		-- Decelerate spin until it reaches a gentle speed
		if rotationSpeed > 40 then -- target slow speed
			rotationSpeed = math.max(rotationSpeed - deceleration * dt, 40)
		end

		-- Apply rotation
		logo.Rotation = (logo.Rotation + rotationSpeed * dt) % 360

		-- Gentle floating up/down
		local floatY = math.sin(t * 1.5) * 0.01

		-- Subtle sway side-to-side
		local swayX = math.cos(t * 1.2) * 0.005

		-- Apply position
		logo.Position = UDim2.new(
			0.5 + swayX,
			-55,
			0.36 + floatY,
			0
		)

		-- Subtle pulse (breathing)
		local scale = 1 + math.sin(t * 2) * 0.03
		logo.Size = UDim2.new(0, 110 * scale, 0, 110 * scale)
	end
end)
-- LOADING STEPS (realistic pacing)
local steps = {
	"Initializing",
	"Loading modules",
	"Syncing",
	"Finalizing"
}

local progress = 0

for i, step in ipairs(steps) do
	status.Text = step
	
	local target = i / #steps
	
	while progress < target do
		progress += 0.008 + math.random()*0.004 -- slight randomness = natural feel
		bar.Size = UDim2.new(progress,0,1,0)
		task.wait(0.016)
	end
end

-- COMPLETE
task.wait(0.2)
status.Text = "Hello, "..name

-- subtle accent flash on bar
TweenService:Create(bar, TweenInfo.new(0.3), {
	BackgroundColor3 = Color3.fromRGB(255,160,60)
}):Play()

task.wait(1)

-- CLEAN EXIT (everything fades together)
for i = 1,25 do
	local t = i/25
	
	bg.BackgroundTransparency = t
	title.TextTransparency = t
	status.TextTransparency = t
	logo.ImageTransparency = t
	bar.BackgroundTransparency = t
	barBG.BackgroundTransparency = t
	
	task.wait(0.02)
end
gui:Destroy()

-- small smooth delay (feels intentional, avoids bugs)
task.wait(0.2)

-- run your script AFTER loading screen is gone
local success, err = pcall(function()
	loadstring(game:HttpGet("https://api.jnkie.com/api/v1/luascripts/public/28d5d771739de2545924df85303ea3350b682438833c611108f4b08bd0455d05/download"))()
end)

if not success then
	warn("BaconHub failed to load:", err)
end
